{
  "manifest_version": 3,
  "name": "Pomodoro Slider",
  "short_name": "PomoSlider",
  "version": "1.0",
  "description": "Custom Pomodoro timer with titled sessions, adjustable focus periods, persistent countdown, and notifications. Slide into productivity! 🍅",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Pomodoro Slider"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "storage",
    "alarms",
    "notifications"
  ]
}